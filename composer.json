{
    "name": "psc-acme/driver-cart",
    "description": "Package driver-cart for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\DriverCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "illuminate/database": "^11.0",
        "symfony/routing": "^7.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "symfony/phpunit-bridge": "^7.0",
        "webforge/object-asserter": "^2.0.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}